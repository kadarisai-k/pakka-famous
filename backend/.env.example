
# ─── Razorpay Payment Gateway ─────────────────────────────────────
# Sign up at https://razorpay.com → Dashboard → Settings → API Keys
# Use TEST keys during development, LIVE keys when deploying
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

PORT=5000
NODE_ENV=development
FRONTEND_URL=https://yourdomain.com

# ─── MongoDB ──────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/pakka-famous

# ─── JWT (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
# ACCESS_TOKEN: short-lived (15 min), must be 64+ hex chars
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX
JWT_ACCESS_EXPIRE=15m
# REFRESH_TOKEN: long-lived (7 days), different secret from access token
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_RANDOM_HEX
JWT_REFRESH_EXPIRE=7d

# ─── Admin Credentials ────────────────────────────────────────────
# These admins must be seeded in the DB with hashed passwords (see seedAdmin.js)
ADMIN_EMAILS=admin@yourdomain.com
# ADMIN_PASSWORD is ONLY used during initial seed — remove after seeding
# ADMIN_PASSWORD=only_used_once_for_seeding

# ─── Cloudinary ───────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Email ────────────────────────────────────────────────────────
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password

# ─── WhatsApp (Twilio) ─────────────────────────────────────────────────────────
# Sign up at https://www.twilio.com and enable WhatsApp sandbox or Business API
TWILIO_ACCOUNT_SID=YOUR_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN
# For sandbox: whatsapp:+14155238886  |  For production: whatsapp:+91XXXXXXXXXX
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Admin WhatsApp numbers (include country code, no spaces)
# Both admins receive every new order alert
ADMIN_WHATSAPP_1=+91XXXXXXXXXX
ADMIN_WHATSAPP_2=+91XXXXXXXXXX

# ─── Email (additional settings) ──────────────────────────────────
# For Gmail: host=smtp.gmail.com, port=587
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_FROM=Pakka Famous <your_gmail@gmail.com>
